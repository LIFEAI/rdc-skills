    "uninstall:unix": "bash scripts/uninstall.sh",
    "update:win": "powershell -ExecutionPolicy Bypass -File scripts/update.ps1",
    "update:unix": "bash scripts/update.sh",
    "validate": "node tests/validate-skills.js"
  }
}
