{
  "manifest_version": 1,
  "skill": "rdc:review",
  "description": "Review runs tsc + lint gates in read-only mode under RDC_TEST; no external writes.",
  "fixture": {
    "prompt": "rdc:review --unattended",
    "env": { "RDC_TEST": "1" }
  },
  "timeout_ms": 480000,
  "assertions": {
    "exit_code": 0,
    "stdout_contains": ["Verdict"]
  },
  "acceptance": {
    "output_contains": [
      "code-review",
      "verify",
      "fresh evidence",
      "tsc",
      "Verdict"
    ],
    "output_not_contains": [
      "pnpm build",
      "raw MCP",
      "CLEAN without"
    ]
  },
  "teardown": { "reset_branch": true }
}
