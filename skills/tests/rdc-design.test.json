{
  "manifest_version": 1,
  "skill": "rdc:design",
  "description": "RDC Design provides Studio-aware design instructions and CLI prompt logging under RDC_TEST.",
  "fixture": {
    "prompt": "rdc:design studio audit the palette page",
    "env": { "RDC_TEST": "1" }
  },
  "assertions": {
    "exit_code": 0,
    "stdout_contains": ["Studio"]
  },
  "acceptance": {
    "output_contains": [
      "Studio",
      "palette",
      "audit"
    ],
    "output_not_contains": [
      "Supabase write",
      "git push",
      "package publish",
      "deploy"
    ]
  },
  "teardown": { "reset_branch": true }
}
