{
  "manifest_version": 1,
  "skill": "rdc:help",
  "description": "Help renders the manifest-driven command reference and decision tree without external writes.",
  "fixture": {
    "prompt": "rdc:help",
    "env": { "RDC_TEST": "1" }
  },
  "assertions": {
    "exit_code": 0,
    "commits_made": { "min": 0 },
    "stdout_contains": ["rdc:help", "Decision Tree"]
  },
  "acceptance": {
    "output_contains": [
      "Direct MCP / curl Access",
      "https://rdc-skills.regendevcorp.com/mcp",
      "rdc_skill_list",
      "rdc_skill_search",
      "rdc_skill_get",
      "\"format\":\"json\""
    ],
    "output_not_contains": [
      "https://rdc-skills.dev.regendevcorp.com/mcp",
      "All user-invocable skills become available as slash commands"
    ]
  },
  "teardown": { "reset_branch": true }
}
