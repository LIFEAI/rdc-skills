{
  "manifest_version": 1,
  "skill": "rdc:report",
  "description": "Report writes a dated markdown file to .rdc/reports/ and emits a verdict line.",
  "fixture": {
    "prompt": "rdc:report --unattended",
    "env": { "RDC_TEST": "1" }
  },
  "assertions": {
    "exit_code": 0,
    "stdout_contains": ["Verdict"]
  },
  "acceptance": {
    "output_contains": [
      "REPORT_STATUS",
      "report_path",
      "completed_count",
      "open_count",
      "Next Session Recommendation"
    ],
    "output_not_contains": [
      "raw MCP",
      "git push",
      "unbounded dump"
    ]
  },
  "teardown": { "reset_branch": true }
}
