{
  "manifest_version": 1,
  "skill": "rdc:status",
  "description": "Status is read-only: prints kanban + health, makes no commits.",
  "fixture": {
    "prompt": "rdc:status",
    "env": { "RDC_TEST": "1" }
  },
  "assertions": {
    "exit_code": 0,
    "commits_made": { "min": 0 },
    "stdout_contains": ["Recommended Next"]
  },
  "acceptance": {
    "output_contains": [
      "Recommended Next",
      "read-only",
      "work items",
      "health"
    ],
    "output_not_contains": [
      "raw MCP",
      "UUID",
      "UPDATE work_items",
      "INSERT"
    ]
  },
  "teardown": { "reset_branch": true }
}
